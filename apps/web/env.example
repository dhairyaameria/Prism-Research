# Copy values into Vercel → Project → Settings → Environment Variables.

# Server-side proxy target for /api/prism/* (no trailing slash). Required for production
# unless you use NEXT_PUBLIC_API_URL below.
API_PROXY_TARGET=https://your-prism-api.example.com

# Optional: browser calls the API directly (recommended for long SSE streams so traffic
# does not pass through Vercel serverless). Add your Vercel URL to API CORS_ORIGINS.
# NEXT_PUBLIC_API_URL=https://your-prism-api.example.com
