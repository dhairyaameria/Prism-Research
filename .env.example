# Copy to `.env` and fill in. (`.env` is gitignored — never commit secrets.)

# --- LLM (Baseten + LiteLLM OpenAI-compatible API) ---
PRISM_LLM_PROVIDER=baseten
BASETEN_API_KEY=
# Shared catalog: https://inference.baseten.co/v1 — list models:
#   curl -s https://inference.baseten.co/v1/models -H "Authorization: Api-Key $BASETEN_API_KEY"
# Llama 4 Maverick (library / per-model URL): https://www.baseten.co/library/llama-4-maverick/ — copy `model_url` → BASETEN_OPENAI_BASE and `model` → PRISM_ADK_MODEL (as openai/<id>).
BASETEN_OPENAI_BASE=https://inference.baseten.co/v1
# Catalog `id` from /v1/models → prefix openai/ (e.g. openai/gpt-oss-120b). Baseten + LiteLLM: single-segment ids are fixed in code.
PRISM_ADK_MODEL=openai/gpt-oss-120b

# PRISM_PIPELINE=adk

# --- Integrations ---
YOU_API_KEY=
# Fast pipeline research merges You.com YDC hits before corpus chunks (set 0 to skip).
# PRISM_FAST_PIPELINE_YOU=1
# PRISM_YOU_MAX_SNIPPETS=5
ENABLE_VERIS_MCP=0
VERIS_DEFAULT_TICKER=DEMO

# --- Database ---
DATABASE_URL=postgresql+asyncpg://prism:prism@localhost:5433/prism

# --- API ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# PRISM_REPO_ROOT=/absolute/path/to/prism

# --- Optional ---
PRISM_USE_EMBEDDINGS=0
